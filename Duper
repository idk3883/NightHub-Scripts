-- ===== Freeze
local function maxFreeze()
    -- Anchor character completely
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Anchored = true
        end
    end

    -- Stop humanoid movement
    local hum = character:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = 0
        hum.JumpPower = 0
    end

    -- Stop all animations
    for _, anim in pairs(character:GetDescendants()) do
        if anim:IsA("AnimationTrack") then
            anim:AdjustSpeed(0)
        end
    end

    -- Freeze tools
    for _, tool in pairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            tool.Activated:Connect(function()
                while true do task.wait() end -- infinite hold
            end)
        end
    end

    -- Overload RenderStepped
    spawn(function()
        while true do
            local t0 = tick()
            repeat until tick() - t0 > 1 -- hold each frame for 1 second
            camera.CFrame = camera.CFrame * CFrame.Angles(0, math.rad(math.random(-2,2)), 0)
        end
    end)
end

button.MouseButton1Click:Connect(maxFreeze)
